# ─── Server Configuration ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Database Configuration ───────────────────────────────────────────────────
# PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/study_club?schema=public"

# ─── Authentication & Security ────────────────────────────────────────────────
# Short-lived access token secret key (must be at least 32 characters for production safety).
JWT_SECRET="dev-jwt-secret-key-with-over-thirty-two-characters-long-key"

# Access token duration (short-lived)
ACCESS_TOKEN_EXPIRY="15m"

# Refresh token retention (days)
REFRESH_TOKEN_EXPIRY_DAYS=30

# ─── Email & Notification Services (SMTP) ────────────────────────────────────
# Nodemailer SMTP transporter details for dispatching verification signup codes.
# Recommended: Use Gmail app password configurations.
MAIL_USER="your-app-email@gmail.com"
MAIL_PASS="four-letter-four-letter-four-letter-four-letter"

# ─── AI Integrations ──────────────────────────────────────────────────────────
# Google Gemini API key used by the KnowNook chatbot controller.
GEMINI_API_KEY="AIzaSyC..."

# ─── Optional Cross-Origin settings ───────────────────────────────────────────
# Comma-separated list of allowed origins (leave commented to use standard defaults)
# CORS_ORIGINS="http://localhost:5173,http://localhost:3000"
# COOKIE_DOMAIN="localhost"
