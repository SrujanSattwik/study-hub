# ─────────────────────────────────────────────────────────────────────────────
# StudyClub — Development Environment
# Copy this file to .env and fill in your local values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Local PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/study_club"

# Docker Compose override (used inside containers)
# DATABASE_URL="postgresql://postgres:postgres@postgres:5432/study_club"

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=study_club

# ── Authentication ────────────────────────────────────────────────────────────
# Minimum 32 characters required (any longer random string is fine for dev)
JWT_SECRET="dev-jwt-secret-key-replace-with-32plus-chars-in-prod"

ACCESS_TOKEN_EXPIRY="15m"
REFRESH_TOKEN_EXPIRY_DAYS=30

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Use a Gmail App Password (Settings > Security > App Passwords)
MAIL_USER="your-email@gmail.com"
MAIL_PASS="xxxx xxxx xxxx xxxx"

# ── AI Integration ────────────────────────────────────────────────────────────
# Google Gemini API key — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY="AIzaSy..."

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins (Vite dev default: http://localhost:5173)
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"
COOKIE_DOMAIN="localhost"

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL the React app uses to reach the API (injected at Vite build time)
VITE_API_URL="http://localhost:3001"
