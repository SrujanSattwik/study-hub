datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../backend/node_modules/.prisma/client"
}

enum Role {
  student
  admin
  owner
}

enum rsvp_status {
  going
  maybe
  declined
  none
}

model User {
  id                   String                 @id @map("user_id") @db.VarChar(36)
  fullName             String?                @map("full_name") @db.VarChar(100)
  email                String                 @unique @db.VarChar(150)
  passwordHash         String                 @map("password_hash") @db.VarChar(255)
  role                 Role                   @default(student)
  createdAt            DateTime               @default(now()) @map("created_at")
  lastLoginAt          DateTime?              @map("last_login_at")

  // Relations
  materials            Material[]
  groupMemberships     GroupMember[]
  createdGroups        StudyGroup[]           @relation("GroupCreator")
  announcements        GroupAnnouncement[]
  eventsCreated        GroupEvent[]
  eventRsvps           EventRsvp[]
  meetingsHosted       GroupMeeting[]
  meetingParticipations MeetingParticipant[]
  messages             GroupMessage[]
  reactions            MessageReaction[]
  posts                CommunityPost[]
  postLikes            PostLike[]
  postComments         PostComment[]
  questions            Question[]
  answers              QuestionAnswer[]
  answerVotes          AnswerVote[]
  uploadedMaterials    GroupMaterial[]
  materialLikes        GroupMaterialLike[]
  materialComments     GroupMaterialComment[]
  downloads            MaterialDownload[]
  notifications        Notification[]
  activityLogs         ActivityLog[]
  bookmarks            UserBookmark[]
  reports              Report[]
  invitationsSent      Invitation[]           @relation("InvitationSender")
  invitationsReceived  Invitation[]           @relation("InvitationReceiver")
  presence             PresenceStatus?
  typingStatuses       TypingStatus[]
  refreshTokens        RefreshToken[]

  @@map("users")
  @@index([role])
}

model RefreshToken {
  id         String    @id @map("token_id") @db.VarChar(36)
  userId     String    @map("user_id") @db.VarChar(36)
  tokenHash  String    @unique @map("token_hash") @db.VarChar(255)
  family     String    @map("family") @db.VarChar(36)
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  replacedBy String?   @map("replaced_by") @db.VarChar(36)
  userAgent  String?   @map("user_agent") @db.VarChar(255)
  ipAddress  String?   @map("ip_address") @db.VarChar(64)
  createdAt  DateTime  @default(now()) @map("created_at")

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
  @@index([userId])
  @@index([family])
  @@index([expiresAt])
}

model Material {
  id            String    @id @db.VarChar(36)
  title         String    @db.VarChar(255)
  description   String?   @db.Text
  type          String?   @db.VarChar(50)
  format        String?   @db.VarChar(50)
  filePath      String?   @map("file_path") @db.VarChar(500)
  link          String?   @db.VarChar(500)
  thumbnail     String?   @db.VarChar(500)
  downloadCount Int       @default(0) @map("download_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  author        String    @default("Anonymous") @db.VarChar(150)
  userId        String?   @map("user_id") @db.VarChar(36)
  subject       String?   @db.VarChar(100)
  difficulty    String?   @db.VarChar(50)

  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("materials")
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model StudyGroup {
  id              String              @id @map("group_id") @db.VarChar(36)
  name            String              @db.VarChar(255)
  description     String?             @db.Text
  category        String?             @db.VarChar(100)
  meetingSchedule String?             @map("meeting_schedule") @db.VarChar(255)
  coverImage      String?             @map("cover_image") @db.VarChar(500)
  icon            String              @default("fas fa-users") @db.VarChar(100)
  createdBy       String?             @map("created_by") @db.VarChar(36)
  createdAt       DateTime            @default(now()) @map("created_at")

  creator         User?               @relation("GroupCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  members         GroupMember[]
  announcements   GroupAnnouncement[]
  events          GroupEvent[]
  meetings        GroupMeeting[]
  messages        GroupMessage[]
  questions       Question[]
  categories      MaterialCategory[]
  materials       GroupMaterial[]
  activityLogs    ActivityLog[]
  invitations     Invitation[]
  typingStatuses  TypingStatus[]

  @@map("study_groups")
}

model GroupMember {
  groupId  String     @map("group_id") @db.VarChar(36)
  userId   String     @map("user_id") @db.VarChar(36)
  role     String     @default("member") @db.VarChar(50)
  joinedAt DateTime   @default(now()) @map("joined_at")
  status   String     @default("approved") @db.VarChar(20)

  group    StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@map("group_members")
  @@index([userId])
  @@index([userId, status])
  @@index([groupId])
}

model GroupAnnouncement {
  id          String     @id @map("announcement_id") @db.VarChar(36)
  groupId     String     @map("group_id") @db.VarChar(36)
  title       String     @db.VarChar(255)
  content     String     @db.Text
  createdBy   String     @map("created_by") @db.VarChar(36)
  createdAt   DateTime   @default(now()) @map("created_at")

  group       StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator     User       @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@map("group_announcements")
}

model GroupEvent {
  id          String      @id @map("event_id") @db.VarChar(36)
  groupId     String      @map("group_id") @db.VarChar(36)
  title       String      @db.VarChar(255)
  description String?     @db.Text
  type        String?     @db.VarChar(50)
  eventDate   DateTime    @map("event_date")
  endDate     DateTime?   @map("end_date")
  location    String      @default("Virtual") @db.VarChar(255)
  createdBy   String      @map("created_by") @db.VarChar(36)
  createdAt   DateTime    @default(now()) @map("created_at")

  group       StudyGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator     User        @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  rsvps       EventRsvp[]

  @@map("group_events")
  @@index([groupId])
  @@index([eventDate])
}

model EventRsvp {
  eventId   String      @map("event_id") @db.VarChar(36)
  userId    String      @map("user_id") @db.VarChar(36)
  status    rsvp_status @default(none)
  createdAt DateTime    @default(now()) @map("created_at")

  event     GroupEvent  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([eventId, userId])
  @@map("event_rsvps")
  @@index([eventId])
}

model GroupMeeting {
  id                    String              @id @map("meeting_id") @db.VarChar(36)
  groupId               String              @map("group_id") @db.VarChar(36)
  title                 String              @db.VarChar(255)
  hostId                String              @map("host_id") @db.VarChar(36)
  status                String              @default("active") @db.VarChar(20)
  isWaitingRoomEnabled  Boolean             @default(false) @map("is_waiting_room_enabled")
  createdAt             DateTime            @default(now()) @map("created_at")
  endedAt               DateTime?           @map("ended_at")

  group                 StudyGroup          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  host                  User                @relation(fields: [hostId], references: [id], onDelete: Cascade)
  participants          MeetingParticipant[]
  recordings            MeetingRecording[]

  @@map("group_meetings")
}

model MeetingParticipant {
  meetingId  String       @map("meeting_id") @db.VarChar(36)
  userId     String       @map("user_id") @db.VarChar(36)
  joinedAt   DateTime     @default(now()) @map("joined_at")
  leftAt     DateTime?    @map("left_at")
  isMuted    Boolean      @default(false) @map("is_muted")
  isCameraOn Boolean      @default(false) @map("is_camera_on")

  meeting    GroupMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([meetingId, userId])
  @@map("meeting_participants")
}

model GroupMessage {
  id          String              @id @map("message_id") @db.VarChar(36)
  groupId     String              @map("group_id") @db.VarChar(36)
  userId      String              @map("user_id") @db.VarChar(36)
  content     String?             @db.Text
  parentId    String?             @map("parent_id") @db.VarChar(36)
  isPinned    Boolean             @default(false) @map("is_pinned")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime?           @updatedAt @map("updated_at")

  group       StudyGroup          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent      GroupMessage?       @relation("MessageReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies     GroupMessage[]      @relation("MessageReplies")
  reactions   MessageReaction[]
  attachments MessageAttachment[]

  @@map("group_messages")
  @@index([groupId])
  @@index([createdAt])
}

model MessageReaction {
  messageId String       @map("message_id") @db.VarChar(36)
  userId    String       @map("user_id") @db.VarChar(36)
  reaction  String       @db.VarChar(50)

  message   GroupMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([messageId, userId, reaction])
  @@map("message_reactions")
}

model MessageAttachment {
  id         String       @id @map("attachment_id") @db.VarChar(36)
  messageId  String       @map("message_id") @db.VarChar(36)
  fileName   String       @map("file_name") @db.VarChar(255)
  filePath   String       @map("file_path") @db.VarChar(500)
  fileType   String       @map("file_type") @db.VarChar(100)
  fileSize   Int          @map("file_size")
  createdAt  DateTime     @default(now()) @map("created_at")

  message    GroupMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("message_attachments")
}

model CommunityPost {
  id          String        @id @map("post_id") @db.VarChar(36)
  userId      String        @map("user_id") @db.VarChar(36)
  content     String        @db.Text
  mediaPath   String?       @map("media_path") @db.VarChar(500)
  mediaType   String?       @map("media_type") @db.VarChar(50)
  isPinned    Boolean       @default(false) @map("is_pinned")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime?     @updatedAt @map("updated_at")

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes       PostLike[]
  comments    PostComment[]

  @@map("community_posts")
  @@index([createdAt])
  @@index([userId])
}

model PostLike {
  postId String        @map("post_id") @db.VarChar(36)
  userId String        @map("user_id") @db.VarChar(36)

  post   CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@map("post_likes")
  @@index([postId])
}

model PostComment {
  id        String        @id @map("comment_id") @db.VarChar(36)
  postId    String        @map("post_id") @db.VarChar(36)
  userId    String        @map("user_id") @db.VarChar(36)
  content   String        @db.Text
  parentId  String?       @map("parent_id") @db.VarChar(36)
  createdAt DateTime      @default(now()) @map("created_at")

  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    PostComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies   PostComment[] @relation("CommentReplies")

  @@map("post_comments")
  @@index([postId])
}

model Question {
  id         String           @id @map("question_id") @db.VarChar(36)
  groupId    String           @map("group_id") @db.VarChar(36)
  userId     String           @map("user_id") @db.VarChar(36)
  title      String           @db.VarChar(255)
  description String          @db.Text
  subject    String?          @db.VarChar(100)
  tags       String?          @db.Text
  isSolved   Boolean          @default(false) @map("is_solved")
  priority   String           @default("medium") @db.VarChar(20)
  viewsCount Int              @default(0) @map("views_count")
  createdAt  DateTime         @default(now()) @map("created_at")

  group      StudyGroup       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers    QuestionAnswer[]

  @@map("questions")
  @@index([groupId])
}

model QuestionAnswer {
  id          String             @id @map("answer_id") @db.VarChar(36)
  questionId  String             @map("question_id") @db.VarChar(36)
  userId      String             @map("user_id") @db.VarChar(36)
  content     String             @db.Text
  isAccepted  Boolean            @default(false) @map("is_accepted")
  createdAt   DateTime           @default(now()) @map("created_at")

  question    Question           @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes       AnswerVote[]
  attachments AnswerAttachment[]

  @@map("question_answers")
  @@index([questionId])
}

model AnswerVote {
  answerId  String         @map("answer_id") @db.VarChar(36)
  userId    String         @map("user_id") @db.VarChar(36)
  voteValue Int            @map("vote_value")

  answer    QuestionAnswer @relation(fields: [answerId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([answerId, userId])
  @@map("answer_votes")
  @@index([answerId])
}

model AnswerAttachment {
  id        String         @id @map("attachment_id") @db.VarChar(36)
  answerId  String         @map("answer_id") @db.VarChar(36)
  fileName  String         @map("file_name") @db.VarChar(255)
  filePath  String         @map("file_path") @db.VarChar(500)
  fileType  String         @map("file_type") @db.VarChar(100)
  fileSize  Int            @map("file_size")
  createdAt DateTime       @default(now()) @map("created_at")

  answer    QuestionAnswer @relation(fields: [answerId], references: [id], onDelete: Cascade)

  @@map("answer_attachments")
}

model MaterialCategory {
  id        String             @id @map("category_id") @db.VarChar(36)
  groupId   String             @map("group_id") @db.VarChar(36)
  name      String             @db.VarChar(100)
  parentId  String?            @map("parent_id") @db.VarChar(36)
  createdAt DateTime           @default(now()) @map("created_at")

  group     StudyGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  parent    MaterialCategory?  @relation("SubCategories", fields: [parentId], references: [id], onDelete: SetNull)
  children  MaterialCategory[] @relation("SubCategories")
  materials GroupMaterial[]

  @@map("material_categories")
  @@index([groupId])
}

model GroupMaterial {
  id          String             @id @map("material_id") @db.VarChar(36)
  groupId     String             @map("group_id") @db.VarChar(36)
  categoryId  String?            @map("category_id") @db.VarChar(36)
  title       String             @db.VarChar(255)
  description String?            @db.Text
  filePath    String?            @map("file_path") @db.VarChar(500)
  fileName    String?            @map("file_name") @db.VarChar(255)
  fileSize    Int?               @map("file_size")
  fileType    String?            @map("file_type") @db.VarChar(100)
  uploadedBy  String?            @map("uploaded_by") @db.VarChar(36)
  tags        String?            @db.Text
  isFavorite  Boolean            @default(false) @map("is_favorite")
  createdAt   DateTime           @default(now()) @map("created_at")

  group       StudyGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  category    MaterialCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  uploader    User?              @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)
  likes       GroupMaterialLike[]
  comments    GroupMaterialComment[]
  downloads   MaterialDownload[]

  @@map("group_materials")
  @@index([groupId])
}

model GroupMaterialLike {
  materialId String        @map("material_id") @db.VarChar(36)
  userId     String        @map("user_id") @db.VarChar(36)

  material   GroupMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([materialId, userId])
  @@map("group_material_likes")
  @@index([materialId])
}

model GroupMaterialComment {
  id         String        @id @map("comment_id") @db.VarChar(36)
  materialId String        @map("material_id") @db.VarChar(36)
  userId     String        @map("user_id") @db.VarChar(36)
  content    String        @db.Text
  createdAt  DateTime      @default(now()) @map("created_at")

  material   GroupMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("group_material_comments")
  @@index([materialId])
}

model MaterialDownload {
  id           String        @id @map("download_id") @db.VarChar(36)
  materialId   String        @map("material_id") @db.VarChar(36)
  userId       String        @map("user_id") @db.VarChar(36)
  downloadedAt DateTime      @default(now()) @map("downloaded_at")

  material     GroupMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("material_downloads")
  @@index([materialId])
  @@index([userId])
}

model Notification {
  id          String   @id @map("notification_id") @db.VarChar(36)
  userId      String   @map("user_id") @db.VarChar(36)
  type        String?  @db.VarChar(50)
  title       String?  @db.VarChar(255)
  content     String?  @db.Text
  link        String?  @db.VarChar(500)
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
  @@index([userId, isRead])
  @@index([createdAt])
}

model ActivityLog {
  id        String     @id @map("log_id") @db.VarChar(36)
  groupId   String     @map("group_id") @db.VarChar(36)
  userId    String     @map("user_id") @db.VarChar(36)
  action    String     @db.Text
  createdAt DateTime   @default(now()) @map("created_at")

  group     StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
  @@index([groupId, createdAt])
  @@index([userId])
}

model UserBookmark {
  id        String   @id @map("bookmark_id") @db.VarChar(36)
  userId    String   @map("user_id") @db.VarChar(36)
  itemType  String?  @map("item_type") @db.VarChar(50)
  itemId    String   @map("item_id") @db.VarChar(36)
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_bookmarks")
  @@index([userId])
}

model Report {
  id        String   @id @map("report_id") @db.VarChar(36)
  userId    String   @map("user_id") @db.VarChar(36)
  itemType  String?  @map("item_type") @db.VarChar(50)
  itemId    String   @map("item_id") @db.VarChar(36)
  reason    String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reports")
  @@index([userId])
}

model Invitation {
  id         String     @id @map("invitation_id") @db.VarChar(36)
  groupId    String     @map("group_id") @db.VarChar(36)
  senderId   String     @map("sender_id") @db.VarChar(36)
  receiverId String     @map("receiver_id") @db.VarChar(36)
  role       String     @default("member") @db.VarChar(50)
  status     String     @default("pending") @db.VarChar(20)
  createdAt  DateTime   @default(now()) @map("created_at")

  group      StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender     User       @relation("InvitationSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User       @relation("InvitationReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@map("invitations")
  @@index([receiverId, status])
  @@index([groupId])
}

model MeetingRecording {
  id              String       @id @map("recording_id") @db.VarChar(36)
  meetingId       String       @map("meeting_id") @db.VarChar(36)
  filePath        String?      @map("file_path") @db.VarChar(500)
  durationSeconds Int?         @map("duration_seconds")
  createdAt       DateTime     @default(now()) @map("created_at")

  meeting         GroupMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("meeting_recordings")
}

model PresenceStatus {
  userId     String   @id @map("user_id") @db.VarChar(36)
  status     String   @default("offline") @db.VarChar(20)
  lastSeenAt DateTime @default(now()) @map("last_seen_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("presence_status")
  @@index([status])
}

model TypingStatus {
  groupId     String     @map("group_id") @db.VarChar(36)
  userId      String     @map("user_id") @db.VarChar(36)
  isTyping    Boolean    @default(false) @map("is_typing")
  lastTypedAt DateTime   @default(now()) @map("last_typed_at")

  group       StudyGroup     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@map("typing_status")
  @@index([groupId])
}
