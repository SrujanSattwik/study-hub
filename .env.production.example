# ─────────────────────────────────────────────────────────────────────────────
# StudyClub — Production Environment
# !! NEVER commit this file with real values !!
# Generate secrets with: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Database ──────────────────────────────────────────────────────────────────
# When using Docker Compose: hostname is the service name "postgres"
# When using managed DB (RDS, Supabase, Neon): full connection string
DATABASE_URL="postgresql://postgres:STRONG_PASSWORD@postgres:5432/study_club"

POSTGRES_USER=postgres
POSTGRES_PASSWORD=STRONG_PASSWORD_MIN_20_CHARS
POSTGRES_DB=study_club

# ── Authentication ────────────────────────────────────────────────────────────
# REQUIRED: minimum 64 characters, cryptographically random
# Generate: openssl rand -hex 32
JWT_SECRET="GENERATE_WITH_openssl_rand_hex_32_MINIMUM_64_CHARS"

ACCESS_TOKEN_EXPIRY="15m"
REFRESH_TOKEN_EXPIRY_DAYS=7

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Use a transactional email provider (SendGrid, Resend, Mailgun, SES)
MAIL_USER="noreply@yourdomain.com"
MAIL_PASS="SMTP_APP_PASSWORD_OR_API_KEY"

# ── AI Integration ────────────────────────────────────────────────────────────
# Production Gemini API key from Google Cloud Console
GEMINI_API_KEY="PROD_GEMINI_API_KEY"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your actual production domain(s) — NO trailing slashes
CORS_ORIGINS="https://yourdomain.com,https://www.yourdomain.com"
COOKIE_DOMAIN=".yourdomain.com"

# ── Frontend ──────────────────────────────────────────────────────────────────
# Public URL of the backend API (used by Vite at build time)
VITE_API_URL="https://api.yourdomain.com"

# ── Future: Object Storage (S3/R2) ────────────────────────────────────────────
# For multi-instance deployments, replace local uploads volume with S3/R2.
# S3_BUCKET_NAME="studyclub-uploads"
# S3_REGION="us-east-1"
# S3_ACCESS_KEY_ID="..."
# S3_SECRET_ACCESS_KEY="..."
